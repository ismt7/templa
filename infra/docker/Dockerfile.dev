# 開発用Dockerfile
FROM node:22-alpine

WORKDIR /app

# セキュリティ: 非rootユーザーを作成
RUN addgroup -g 1001 -S appgroup && \
    adduser -S -u 1001 -G appgroup appuser

# パッケージファイルをコピー
COPY package.json package-lock.json* yarn.lock* pnpm-lock.yaml* ./

# 依存関係をインストール
RUN npm ci

# ソースコードをコピー
COPY --chown=appuser:appgroup . .

# 非rootユーザーに切り替え
USER appuser

# ポート公開
EXPOSE 3000

# 開発サーバー起動
CMD ["npm", "run", "dev"]
